generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces   Workspace[]
  notes        Note[]
  images       ImageAsset[]
  files        FileAsset[]
  links        Link[]
  reminders    Reminder[]
  workflows    Workflow[]
}

model Workspace {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model Note {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  title       String?
  content     String
  type        String   @default("text")
  tags        String[]
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model ImageAsset {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  imageUrl      String
  originalName  String?
  ocrText       String?
  aiSummary     String?
  extractedData Json?
  tags          String[]
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

model FileAsset {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  filename      String
  fileUrl       String
  fileType      String
  extractedText String?
  aiSummary     String?
  tags          String[]
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

model Link {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  title       String?
  url         String
  description String?
  favicon     String?
  category    String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Reminder {
  id           String   @id @default(cuid())
  userId       String
  workspaceId  String?
  title        String
  description  String?
  remindAt     DateTime
  status       String   @default("pending")
  sourceNoteId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model Workflow {
  id               String   @id @default(cuid())
  userId           String
  workspaceId      String?
  name             String
  inputType        String
  extractionPrompt String
  outputFormat     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])
  runs             WorkflowRun[]
}

model WorkflowRun {
  id         String   @id @default(cuid())
  workflowId String
  userId     String
  inputFiles Json?
  result     Json?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  workflow   Workflow @relation(fields: [workflowId], references: [id])
}
